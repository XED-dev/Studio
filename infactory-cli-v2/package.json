{
  "name": "@xed-dev/infactory-cli",
  "description": "inFactory CLI — Server-Management, Site-Setup und Health-Monitoring",
  "version": "2.0.0-alpha.1",
  "author": "recode@ /DAO",
  "bin": {
    "infactory": "./bin/run.js"
  },
  "bugs": "https://github.com/XED-dev/Studio/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.80",
    "@oclif/plugin-plugins": "^5"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://studio.xed.dev",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "infactory",
    "dirname": "infactory",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-not-found",
      "@oclif/plugin-plugins"
    ],
    "hooks": {
      "command_not_found": "./dist/hooks/command-not-found"
    },
    "topicSeparator": " ",
    "topics": {
      "admin": {
        "description": "Admin-User verwalten"
      },
      "server": {
        "description": "Infactory-Service-Lifecycle (start/stop/restart)"
      },
      "site": {
        "description": "Site-Management (Setup, Update, Status)"
      }
    }
  },
  "repository": "XED-dev/Studio",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
