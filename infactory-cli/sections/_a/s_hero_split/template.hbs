  <section data-snippet="s_hero_split" class="g_section">
    <div class="g_grid" style="--g-cols: 12">
      <div class="g_item g_col-7" data-zone="headline" data-editable="true" data-type="text">
        <span class="badge">{{zones.eyebrow.value}}</span>
        <h1>{{zones.headline.value}}</h1>
        <p>{{{zones.subline.value}}}</p>
      </div>
      <div class="g_item g_col-5" data-zone="image" data-editable="true" data-type="image">
        <div style="aspect-ratio: 4/3; background: linear-gradient(135deg, {{zones.image_gradient.from}} 0%, {{zones.image_gradient.to}} 100%); border-radius: 0.5rem;"></div>
      </div>
    </div>
  </section>