  <script>
  (function(){
    // Mobile Nav Toggle
    var btn=document.querySelector('.js-nav-toggle'),nav=document.getElementById('mobile-nav');
    if(btn&&nav){
      btn.addEventListener('click',function(){
        var open=btn.getAttribute('aria-expanded')==='true';
        btn.setAttribute('aria-expanded',String(!open));
        nav.hidden=open;
        document.querySelector('.site-nav').classList.toggle('open',!open);
        btn.setAttribute('aria-label',open?'Menü öffnen':'Menü schließen');
      });
    }
    // Mobile Dropdown Toggle (Klick auf Parent öffnet/schließt Sub)
    document.querySelectorAll('.nav-mobile > .has-children > a').forEach(function(a){
      a.addEventListener('click',function(e){
        if(window.innerWidth<1100){
          e.preventDefault();
          a.parentElement.classList.toggle('open');
        }
      });
    });
    // Sticky Nav
    var header=document.querySelector('.site-nav--sticky');
    if(header){
      window.addEventListener('scroll',function(){
        header.classList.toggle('scrolled',window.scrollY>100);
      },{passive:true});
    }
  })();
  </script>

