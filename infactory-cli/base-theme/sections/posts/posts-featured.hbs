{{!--
  sections/posts/posts-featured.hbs — Featured Posts
  Großer Featured Post oben + 3 kleine Cards darunter.
  Zeigt Posts mit featured:true.
  Presets: blog
--}}
<section class="c-posts-featured" aria-label="Featured">
  <div class="l-wrapper">
    <h2 class="c-posts-featured__heading">Empfohlen</h2>
    {{#get "posts" filter="featured:true" limit="4" include="tags,authors"}}
      <div class="c-posts-featured__layout">
        {{#foreach posts}}
          {{#if @first}}
          <article class="c-post-card c-post-card--large">
            {{#if feature_image}}
            <a href="{{url}}" class="c-post-card__image" tabindex="-1" aria-hidden="true">
              <img
                srcset="{{img_url feature_image size="m" format="webp"}} 600w,
                        {{img_url feature_image size="l" format="webp"}} 960w,
                        {{img_url feature_image size="xl" format="webp"}} 1200w"
                sizes="(max-width: 767px) 100vw, 66vw"
                src="{{img_url feature_image size="l"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="lazy"
              >
            </a>
            {{/if}}
            <div class="c-post-card__body">
              {{#if primary_tag}}<span class="c-post-card__tag">{{primary_tag.name}}</span>{{/if}}
              <h3 class="c-post-card__title"><a href="{{url}}">{{title}}</a></h3>
              {{#if custom_excerpt}}<p class="c-post-card__excerpt">{{custom_excerpt}}</p>{{/if}}
            </div>
          </article>
          {{else}}
          <article class="c-post-card c-post-card--small">
            {{#if feature_image}}
            <a href="{{url}}" class="c-post-card__image" tabindex="-1" aria-hidden="true">
              <img src="{{img_url feature_image size="s" format="webp"}}" alt="{{title}}" loading="lazy">
            </a>
            {{/if}}
            <div class="c-post-card__body">
              <h3 class="c-post-card__title"><a href="{{url}}">{{title}}</a></h3>
              <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D. MMM YYYY"}}</time>
            </div>
          </article>
          {{/if}}
        {{/foreach}}
      </div>
    {{/get}}
  </div>
</section>
