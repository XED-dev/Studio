{{!-- Section: Icon Cards — Karten mit Bild/Icon, Titel und Text
     Verwendet: Pages mit Tag #icon-card (feature_image als Icon/Illustration)
     Tokens: --color-bg, --color-primary, --color-text, --font-heading --}}

{{#get "pages" filter="tag:hash-icon-card" limit="6" include="tags"}}
  {{#if pages.length}}
  <section class="c-icon-cards" aria-label="Leistungen">
    <div class="l-wrapper">
      <div class="c-icon-cards__grid">
        {{#foreach pages}}
        <article class="c-icon-card">
          {{#if feature_image}}
          <div class="c-icon-card__icon">
            <img src="{{img_url feature_image size="s"}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="lazy" />
          </div>
          {{/if}}
          <h3 class="c-icon-card__title">
            <a href="{{url}}">{{title}}</a>
          </h3>
          {{#if custom_excerpt}}
          <p class="c-icon-card__text">{{custom_excerpt}}</p>
          {{/if}}
        </article>
        {{/foreach}}
      </div>
    </div>
  </section>
  {{/if}}
{{/get}}
