{{!--
  sections/misc/about-split.hbs — About Split
  Über-uns Section mit Bild links, Text rechts.
  Verwendet eine Page mit dem Tag #about.
  Presets: studio, blog
--}}
<section class="c-about-split" aria-label="Über uns">
  <div class="l-wrapper">
    {{#get "pages" filter="tag:hash-about" limit="1"}}
      {{#foreach pages}}
      <div class="c-about-split__row">
        {{#if feature_image}}
        <div class="c-about-split__media">
          <img
            srcset="{{img_url feature_image size="s" format="webp"}} 320w,
                    {{img_url feature_image size="m" format="webp"}} 600w,
                    {{img_url feature_image size="l" format="webp"}} 960w"
            sizes="(max-width: 767px) 100vw, 50vw"
            src="{{img_url feature_image size="m"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
          >
        </div>
        {{/if}}
        <div class="c-about-split__content">
          <h2 class="c-about-split__title">{{title}}</h2>
          <div class="c-about-split__text">{{content}}</div>
        </div>
      </div>
      {{/foreach}}
    {{/get}}
  </div>
</section>
