{{!-- Section: Hero Image — Vollbild-Bild mit Separator am unteren Rand
     Verwendet: feature_image der aktuellen Seite oder @site.cover_image
     Tokens: --color-primary --}}

{{#if feature_image}}
<section class="c-hero-image" aria-label="Hero">
  <img src="{{img_url feature_image size="xl"}}"
       alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
       loading="eager" />
  <div class="c-hero-image__separator"></div>
</section>
{{else}}
  {{#if @site.cover_image}}
  <section class="c-hero-image" aria-label="Hero">
    <img src="{{img_url @site.cover_image size="xl"}}"
         alt="{{@site.title}}"
         loading="eager" />
    <div class="c-hero-image__separator"></div>
  </section>
  {{/if}}
{{/if}}
