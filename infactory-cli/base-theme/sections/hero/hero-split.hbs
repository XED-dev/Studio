{{!--
  sections/hero/hero-split.hbs — Hero Split
  50/50 Layout: Text links, Bild rechts.
  Verwendet den neuesten Featured Post als Inhalt.
  Presets: saas, studio
--}}
<section class="c-hero c-hero--split">
  <div class="c-hero__inner l-wrapper">
    {{#get "posts" filter="featured:true" limit="1" include="tags"}}
      {{#foreach posts}}
      <div class="c-hero__content">
        {{#if primary_tag}}<span class="c-hero__tag">{{primary_tag.name}}</span>{{/if}}
        <h1 class="c-hero__title">{{title}}</h1>
        {{#if custom_excerpt}}<p class="c-hero__description">{{custom_excerpt}}</p>{{/if}}
        <a href="{{url}}" class="c-hero__cta">Mehr erfahren</a>
      </div>
      {{#if feature_image}}
      <div class="c-hero__media">
        <img
          srcset="{{img_url feature_image size="s" format="webp"}} 320w,
                  {{img_url feature_image size="m" format="webp"}} 600w,
                  {{img_url feature_image size="l" format="webp"}} 960w,
                  {{img_url feature_image size="xl" format="webp"}} 1200w"
          sizes="(max-width: 767px) 100vw, 50vw"
          src="{{img_url feature_image size="l"}}"
          alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
          loading="eager"
        >
      </div>
      {{/if}}
      {{/foreach}}
    {{/get}}
  </div>
</section>
