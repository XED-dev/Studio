{{!--
  author.hbs — Autor-Archiv
  Erbt von: default.hbs
--}}

{{!< default}}

<div class="l-wrapper" style="padding: 3rem 0;">
  <header class="c-author-header" style="text-align: center; margin-bottom: 2rem;">
    {{#if profile_image}}
      <img src="{{img_url profile_image size="s"}}" alt="{{name}}" width="120" height="120" loading="eager" style="border-radius: 50%; margin: 0 auto 1rem;">
    {{/if}}
    <h1>{{name}}</h1>
    {{#if bio}}<p>{{bio}}</p>{{/if}}
  </header>

  <div class="l-grid l-grid--3">
    {{#foreach posts}}
    <article class="c-news-card">
      {{#if feature_image}}
      <a href="{{url}}" class="c-news-card__image">
        <img src="{{img_url feature_image size="m"}}" alt="{{title}}" width="600" height="338" loading="lazy">
      </a>
      {{/if}}
      <div class="c-news-card__body">
        <h3 class="c-news-card__title"><a href="{{url}}">{{title}}</a></h3>
        <time class="c-news-card__date" datetime="{{date format="YYYY-MM-DD"}}">{{date published_at format="D. MMMM YYYY"}}</time>
      </div>
    </article>
    {{/foreach}}
  </div>
</div>
