{{!--
  partials/pagination.hbs — Ghost Pagination
--}}
{{#if pagination}}
{{#if pagination.next}}
<nav class="c-pagination" aria-label="Seitennavigation">
  <div style="display:flex;justify-content:center;gap:1rem;padding:2rem 0;">
    {{#if pagination.prev}}
      <a href="{{page_url pagination.prev}}">← Neuere Beiträge</a>
    {{/if}}
    <span>Seite {{pagination.page}} von {{pagination.pages}}</span>
    <a href="{{page_url pagination.next}}">Ältere Beiträge →</a>
  </div>
</nav>
{{else}}
  {{#if pagination.prev}}
  <nav class="c-pagination" aria-label="Seitennavigation">
    <div style="display:flex;justify-content:center;gap:1rem;padding:2rem 0;">
      <a href="{{page_url pagination.prev}}">← Neuere Beiträge</a>
      <span>Seite {{pagination.page}} von {{pagination.pages}}</span>
    </div>
  </nav>
  {{/if}}
{{/if}}
{{/if}}
