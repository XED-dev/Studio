{{!--
  error-404.hbs — 404 Seite nicht gefunden
  Erbt von: default.hbs
--}}

{{!< default}}

<div class="l-wrapper" style="padding: 6rem 0; text-align: center;">
  <div style="font-size: 5rem; color: var(--color-border); font-weight: 700; margin-bottom: 1rem;">404</div>
  <h1>Seite nicht gefunden</h1>
  <p style="color: var(--color-text-muted);">Diese Seite existiert nicht oder wurde verschoben.</p>
  <a href="{{@site.url}}" style="display: inline-block; margin-top: 1.5rem; padding: 0.7rem 2rem; background: var(--color-primary); color: #fff; text-decoration: none; border-radius: 4px;">Zur Startseite</a>
</div>
