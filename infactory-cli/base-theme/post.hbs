{{!--
  post.hbs — Blog-Post / Aktuelles
  Erbt von: default.hbs
  WICHTIG: {{#post}} öffnet den Post-Kontext!
--}}

{{!< default}}

{{#post}}
<article class="c-article c-article--post" itemscope itemtype="https://schema.org/Article">

  {{#if feature_image}}
  <div class="c-hero-image">
    <img
      srcset="{{img_url feature_image size="l"}} 1000w, {{img_url feature_image size="xl"}} 2000w"
      sizes="100vw"
      src="{{img_url feature_image size="xl"}}"
      alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
      width="2000" height="600" loading="eager" itemprop="image"
    >
  </div>
  {{/if}}

  <div class="c-title-bar">
    <div class="l-wrapper">
      {{#if primary_tag}}
        <div class="c-article__tag">
          <a href="{{primary_tag.url}}">{{primary_tag.name}}</a>
        </div>
      {{/if}}
      <h1 class="c-title-bar__heading" itemprop="headline">{{title}}</h1>
      <div class="c-article__meta">
        <time datetime="{{date format="YYYY-MM-DD"}}" itemprop="datePublished">
          {{date published_at format="D. MMMM YYYY"}}
        </time>
        <span class="c-article__reading-time">{{reading_time}}</span>
      </div>
    </div>
  </div>

  <div class="c-article__body l-wrapper gh-content" itemprop="articleBody">
    {{content}}
  </div>

  {{#if tags}}
  <footer class="c-article__footer l-wrapper">
    <div class="c-article__taglist" aria-label="Artikel-Tags">
      {{#foreach tags}}
        <a href="{{url}}" class="c-tag">{{name}}</a>
      {{/foreach}}
    </div>
  </footer>
  {{/if}}

</article>
{{/post}}
