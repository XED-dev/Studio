# inFactory Server — Factory Floor Controller
# Kopiere nach .env und passe an.

# Server
INFACTORY_PORT=3333
INFACTORY_API_KEY=              # Pflicht! Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Ghost Instanzen (DEV)
GHOST_DEV_URL=http://localhost:2369
GHOST_DEV_KEY=                  # Ghost Admin API Key (id:secret) — aus Ghost Admin > Integrations
GHOST_DEV_CONTENT_PATH=/var/ghost/steirischursprung.at/content

# Ghost Instanzen (WEB/Prod)
GHOST_WEB_URL=http://localhost:2368
GHOST_WEB_KEY=                  # Ghost Admin API Key (id:secret)
GHOST_WEB_CONTENT_PATH=/var/ghost/de.steirischursprung.at/content

# inFactory CLI Pfad (relativ zum Server)
INFACTORY_CLI_PATH=../infactory-cli

# Bild-Archiv (optional — für Image Migration)
IMAGE_ARCHIVE_PATH=             # z.B. /var/ghost/archive/www.steirischursprung.at
